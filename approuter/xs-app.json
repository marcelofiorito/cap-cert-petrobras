{
  "authenticationMethod": "route",
  "welcomeFile": "/certmanagement/index.html",
  "routes": [
    {
      "source": "^/CertService/(.*)$",
      "target": "/CertService/$1",
      "destination": "cert-srv-api",
      "authenticationType": "xsuaa",
      "csrfProtection": true
    },
    {
      "source": "^/(.*)$",
      "target": "$1",
      "service": "html5-apps-repo-rt",
      "authenticationType": "xsuaa"
    }
  ]
}
