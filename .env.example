# Variáveis de ambiente — copie para .env e preencha

# ── BTP Cloud Foundry ──────────────────────────────────────────────────────────
CF_API=https://api.cf.us10.hana.ondemand.com
CF_ORG=sa-build-platform-org
CF_SPACE=DEV

# ── XSUAA (autenticação da aplicação) ─────────────────────────────────────────
# Obtido via: cf service-key cap-joule-auth joule-dest-key
XSUAA_CLIENT_ID={{XSUAA_CLIENT_ID}}
XSUAA_CLIENT_SECRET=<obter via cf service-key>
XSUAA_URL=https://{{XSUAA_DOMAIN}}

# ── Endpoints das aplicações ───────────────────────────────────────────────────
# Interface Fiori Elements (via App Router)
APP_URL=https://{{APPROUTER_HOST}}/certmanagement/index.html

# OData API (autenticado via Bearer token)
ODATA_URL=https://{{SRV_HOST}}/CertService
