# Variáveis de ambiente — copie para .env e preencha
# NUNCA commite o arquivo .env ou credenciais reais

# ── BTP Cloud Foundry ──────────────────────────────────────────────────────────
CF_API=https://api.cf.<region>.hana.ondemand.com
CF_ORG=<sua-org>
CF_SPACE=<seu-space>

# ── XSUAA (autenticação da aplicação) ─────────────────────────────────────────
# Obtido via: cf service-key <xsuaa-instance> <key-name>
XSUAA_CLIENT_ID=<obter via cf service-key>
XSUAA_CLIENT_SECRET=<obter via cf service-key>
XSUAA_URL=https://<subaccount>.authentication.<region>.hana.ondemand.com

# Basic Auth = base64(clientId:clientSecret) — gerar localmente, nunca commitar
XSUAA_BASIC_AUTH=<base64 de clientId:clientSecret>

# ── Endpoints das aplicações ───────────────────────────────────────────────────
APP_URL=https://<approuter-url>/certmanagement/index.html
ODATA_URL=https://<srv-url>/CertService
